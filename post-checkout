#!/usr/bin/env bash

# Automatically installed by DDEV Branch Isolation Add-on.
# Arguments: $1: Previous HEAD ref, $2: New HEAD ref, $3: 1 if branch checkout, 0 if file checkout
if [ "$3" != "1" ]; then
  exit 0
fi

if ! command -v ddev >/dev/null 2>&1; then
  exit 0
fi

# If git isn't available or we're not in a worktree, do nothing.
if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

TOPLEVEL="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
if [ -z "$TOPLEVEL" ] || [ ! -d "$TOPLEVEL" ]; then
  exit 0
fi

cd "$TOPLEVEL" || exit 0

# If git was invoked from a subdirectory, move into it to find the DDEV project
if [ -n "$GIT_PREFIX" ]; then
  cd "$GIT_PREFIX" || exit 0
fi

# Guard: only run inside a DDEV project that has this add-on's commands installed.
# This prevents the repo-wide hook from running in other worktrees.
if [ ! -f ".ddev/config.yaml" ]; then
  exit 0
fi

if [ ! -f ".ddev/commands/host/.dbranch-provision" ] || [ ! -f ".ddev/commands/host/.dbranch-drop" ]; then
  exit 0
fi

ddev dbranch provision || true
ddev dbranch drop orphaned || true
