#!/usr/bin/env bash
#ddev-generated

## Description: Provisions an isolated database for the current Git branch.
## Usage: .dbranch-provision
## Example: "ddev dbranch provision"

cd "$DDEV_APPROOT" || exit 1

# Ensure DDEV project is running before attempting MySQL queries
if ! ddev describe | grep -q 'OK'; then
  echo "DDEV is not fully running. Skipping automatic database provisioning."
  exit 0
fi

TARGET_DIR="${DDEV_APPROOT}"
if [ -f .ddev/.dbranch-config ]; then
  ACTIVE_WORKTREE=$(grep "^ACTIVE_WORKTREE=" .ddev/.dbranch-config | cut -d '=' -f 2)
  if [ -n "$ACTIVE_WORKTREE" ] && [ -d "${DDEV_APPROOT}/$ACTIVE_WORKTREE" ]; then
    TARGET_DIR="${DDEV_APPROOT}/$ACTIVE_WORKTREE"
  fi
fi
BRANCH=$(git -C "$TARGET_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ -f .ddev/.dbranch-config ]; then
  source .ddev/.dbranch-config
  if [ -n "$ACTIVE_BRANCH" ]; then
    BRANCH="$ACTIVE_BRANCH"
  fi
fi

# If we are on develop, main, or master, do nothing for provisioning
if [[ "$BRANCH" != "develop" && "$BRANCH" != "main" && "$BRANCH" != "master" && "$BRANCH" != "HEAD" ]]; then
  DB_NAME="db_$(echo "$BRANCH" | sed -e 's/[^a-zA-Z0-9_]/_/g')"

  echo "Checking if DDEV database '$DB_NAME' exists..."

  DB_EXISTS=$(ddev mysql -N -e "SHOW DATABASES LIKE '$DB_NAME';" | grep "$DB_NAME")

  if [ -z "$DB_EXISTS" ]; then
    echo "Database '$DB_NAME' does not exist."

    # Safely prompt the user if they are running in an interactive terminal
    if exec < /dev/tty 2>/dev/null; then
      echo -n "Provision an isolated database for this branch? [y/N] (Defaults to N in 10s): " > /dev/tty
      read -t 10 PROVISION || PROVISION="n"
      echo "" > /dev/tty
    else
      echo "No interactive terminal found. Skipping isolated database provisioning."
      PROVISION="n"
    fi

    if [[ "$PROVISION" =~ ^[Yy]$ ]]; then
      echo "Provisioning a new isolated environment..."
      echo "Creating database in MariaDB..."
      ddev mysql -e "CREATE DATABASE IF NOT EXISTS $DB_NAME;"

      echo "Calling ddev dbranch init to populate the database..."
      ddev dbranch init
    else
      echo "Skipped. Your Drupal site will safely fall back to the main DB."
    fi
  else
    echo "Database '$DB_NAME' already exists. Switching active connection automatically."
  fi
fi
