#!/usr/bin/env bash
#ddev-generated

## Description: Initializes a branch database with the latest local dump and runs updates.
## Usage: .dbranch-init [database_name]
## Example: "ddev dbranch init db_feature_xyz"

cd "$DDEV_APPROOT" || exit 1

# If no DB name is provided, determine it from the current branch
if [ -z "$1" ]; then
  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  if [[ "$BRANCH" == "develop" || "$BRANCH" == "main" || "$BRANCH" == "master" || "$BRANCH" == "HEAD" || -z "$BRANCH" ]]; then
    DB_NAME="db"
  else
    DB_NAME="db_$(echo "$BRANCH" | sed -e 's/[^a-zA-Z0-9_]/_/g')"
  fi
else
  DB_NAME="$1"
fi

DUMP_FILE="$2"

# Allow custom configuration via a local config file
DUMP_DIR="."
if [ -f .ddev/dbranch-config ]; then
  source .ddev/dbranch-config
fi
DUMP_DIR="${DUMP_DIR:-.}"

if [ -z "$DUMP_FILE" ]; then
  echo "Looking for the latest database dump (*.sql.gz) in '$DUMP_DIR'..."
  DUMP_FILE=$(ls -t "$DUMP_DIR"/*.sql.gz 2>/dev/null | head -n 1)
fi

if [ -z "$DUMP_FILE" ] || [ ! -f "$DUMP_FILE" ]; then
  echo "Error: Could not find a valid .sql.gz dump in '$DUMP_DIR'."
  echo "Please ensure a database dump exists or configure the search directory in .ddev/dbranch-config"
  exit 1
fi

echo "Importing dump '$DUMP_FILE' into database '$DB_NAME'..."
ddev import-db --database="$DB_NAME" --file="$DUMP_FILE"

# Only run updates if drush is available
if ddev drush --version >/dev/null 2>&1; then
  echo "Running Drupal updates and config import..."
  ddev drush updb -y
  ddev drush cim -y
  ddev drush cr
  ddev drush uli
fi
