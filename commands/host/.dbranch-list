#!/usr/bin/env bash
#ddev-generated

## Description: Lists isolated databases created for branches.
## Usage: .dbranch-list
## Example: "ddev dbranch list"

cd "$DDEV_APPROOT" || exit 1

if ! ddev describe | grep -q 'OK'; then
  echo "DDEV is not running. Cannot list databases."
  exit 1
fi

TARGET_DIR="${DDEV_APPROOT}"
if [ -f .ddev/.dbranch-config ]; then
  ACTIVE_WORKTREE=$(grep "^ACTIVE_WORKTREE=" .ddev/.dbranch-config | cut -d '=' -f 2)
  if [ -n "$ACTIVE_WORKTREE" ] && [ -d "${DDEV_APPROOT}/$ACTIVE_WORKTREE" ]; then
    TARGET_DIR="${DDEV_APPROOT}/$ACTIVE_WORKTREE"
  fi
fi

CURRENT_BRANCH=$(git -C "$TARGET_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ -f .ddev/.dbranch-config ]; then
  source .ddev/.dbranch-config
  if [ -n "$ACTIVE_BRANCH" ]; then
    CURRENT_BRANCH="$ACTIVE_BRANCH"
  fi
fi

if [[ "$CURRENT_BRANCH" == "develop" || "$CURRENT_BRANCH" == "main" || "$CURRENT_BRANCH" == "master" || "$CURRENT_BRANCH" == "HEAD" ]]; then
  CURRENT_DB="db"
else
  CURRENT_DB="db_$(echo "$CURRENT_BRANCH" | sed -e 's/[^a-zA-Z0-9_]/_/g')"
fi

# Get active branches (excluding [gone]) to determine which DBs are valid
ACTIVE_BRANCHES=$(git -C "$TARGET_DIR" for-each-ref --format '%(refname:short) %(upstream:track)' refs/heads | awk '$2 != "[gone]" {print $1}')
VALID_DBS=$(echo "$ACTIVE_BRANCHES" | sed -e 's/[^a-zA-Z0-9_]/_/g' | awk '{print "db_"$1}')
VALID_DBS="$VALID_DBS db db_develop db_main db_master"

EXISTING_DBS=$(ddev mysql -N -e "SHOW DATABASES;" | grep -E '^db$|^db_')

echo "--- Isolated Branch Databases ---"

if [ -z "$EXISTING_DBS" ]; then
  echo "No isolated branch databases found."
  exit 0
fi

for DB in $EXISTING_DBS; do
  if [ "$DB" == "$CURRENT_DB" ]; then
    echo "🟢 $DB (Active: $CURRENT_BRANCH)"
  elif [[ "$DB" == "db" || "$DB" == "db_develop" || "$DB" == "db_main" || "$DB" == "db_master" ]]; then
    echo "🟡 $DB (Protected)"
  elif echo "$VALID_DBS" | grep -qw "$DB"; then
    echo "⚪ $DB"
  else
    echo "🔴 $DB (Orphaned - run 'ddev dbranch drop orphaned' to clean up)"
  fi
done
