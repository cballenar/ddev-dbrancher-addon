#!/usr/bin/env bash
#ddev-generated

## Description: Drops the isolated database for a specified branch to free up space.
## Usage: .dbranch-drop <branch_name | current | orphaned>
## Example: "ddev dbranch drop orphaned"

# When executing a ddev host command, $DDEV_APPROOT is the project root.
cd "$DDEV_APPROOT" || exit 1

if [ -z "$1" ]; then
  echo "Error: A target must be specified."
  echo "Usage: ddev dbranch drop <branch_name | current | orphaned>"
  exit 1
fi

TARGET="$1"

# Ensure DDEV project is running before attempting MySQL queries
if ! ddev describe | grep -q 'OK'; then
  if [ "$TARGET" == "orphaned" ]; then
    echo "DDEV is not fully running. Skipping orphaned database cleanup."
    exit 0
  else
    echo "Error: DDEV is not running. Cannot drop database."
    exit 1
  fi
fi

if [ "$TARGET" == "orphaned" ]; then
  echo "---"
  echo "Scanning for orphaned isolated databases..."
  # Get all local branches, EXCLUDING those that are tracking a deleted remote branch
  ACTIVE_BRANCHES=$(git for-each-ref --format '%(refname:short) %(upstream:track)' refs/heads | awk '$2 != "[gone]" {print $1}')
  VALID_DBS=$(echo "$ACTIVE_BRANCHES" | sed -e 's/[^a-zA-Z0-9_]/_/g' | awk '{print "db_"$1}')
  # Load config
  PROTECTED_BRANCHES="develop,main,master,HEAD"
  if [ -f .ddev/.dbranch-config ]; then
    source .ddev/.dbranch-config
  fi

  # Always keep default databases and protected branches
  IFS=',' read -ra PROT_ARR <<< "$PROTECTED_BRANCHES"
  VALID_DBS="$VALID_DBS db"
  for pb in "${PROT_ARR[@]}"; do
    if [ "$pb" != "HEAD" ]; then
      VALID_DBS="$VALID_DBS db_$(echo "$pb" | sed -e 's/[^a-zA-Z0-9_]/_/g')"
    fi
  done

  EXISTING_DBS=$(ddev mysql -N -e "SHOW DATABASES LIKE 'db\_%';" 2>/dev/null | grep -E '^db_')

  for EXIST_DB in $EXISTING_DBS; do
    if ! echo "$VALID_DBS" | grep -qw "$EXIST_DB"; then
      echo "Branch for database '$EXIST_DB' no longer exists locally (or was deleted remotely). Dropping database to free space..."
      ddev mysql -e "DROP DATABASE \`$EXIST_DB\`;"
    fi
  done
  exit 0
fi

if [ "$TARGET" == "current" ]; then
  BRANCH=$(git rev-parse --abbrev-ref HEAD)
else
  BRANCH="$TARGET"
fi

# Load config (if not already loaded)
if [ -z "$PROTECTED_BRANCHES" ]; then
  PROTECTED_BRANCHES="develop,main,master,HEAD"
  if [ -f .ddev/.dbranch-config ]; then
    source .ddev/.dbranch-config
  fi
fi

if [[ ",$PROTECTED_BRANCHES," == *",$BRANCH,"* ]]; then
  echo "Cannot delete main or protected databases."
  exit 1
fi

DB_NAME="db_$(echo "$BRANCH" | sed -e 's/[^a-zA-Z0-9_]/_/g')"

echo "Dropping database '$DB_NAME'..."
ddev mysql -e "DROP DATABASE IF EXISTS $DB_NAME;"
echo "Database removed. Don't forget to delete the Git branch: git branch -D $BRANCH"
